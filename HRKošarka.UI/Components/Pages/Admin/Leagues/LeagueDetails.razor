@page "/leagues/{Id:guid}"
@using HRKošarka.UI.Services.Base
@inherits HRKošarka.UI.Components.Base.PermissionBaseComponent

<PageTitle>League Details - Basketball Management</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="details-container">
    @if (_isLoading)
    {
        <div class="loading-state">
            <MudProgressCircular Size="Size.Large" Indeterminate="true" />
            <MudText Typo="Typo.h6">Loading league details...</MudText>
        </div>
    }
    else if (_league != null)
    {
        <MudPaper Class="details-paper" Elevation="2">

            <div class="details-actions-row">
                <div class="details-actions-group">

                    <AuditHistory DateCreated="@_league.DateCreated"
                                  DateModified="@_league.DateModified"
                                  DateDeleted="@_league.DateDeleted"
                                  CreatedBy="@_league.CreatedBy"
                                  ModifiedBy="@_league.ModifiedBy"
                                  DeletedBy="@_league.DeletedBy" />

                    <AuthorizeView Roles="Administrator">
                        <Authorized>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       OnClick="@(() => NavigationManager.NavigateTo($"/admin/leagues/{Id}/edit"))"
                                       Class="action-btn details-action-btn">
                                Edit
                            </MudButton>

                            @if (_league.IsActive)
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Warning"
                                           StartIcon="@Icons.Material.Filled.Pause"
                                           OnClick="@(() => _showDeactivateDialog = true)"
                                           Disabled="_isProcessing"
                                           Class="action-btn details-action-btn">
                                    Deactivate
                                </MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Success"
                                           StartIcon="@Icons.Material.Filled.PlayArrow"
                                           OnClick="@(() => _showActivateDialog = true)"
                                           Disabled="_isProcessing"
                                           Class="action-btn details-action-btn">
                                    Activate
                                </MudButton>
                            }

                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Delete"
                                       OnClick="@(() => _showDeleteDialog = true)"
                                       Disabled="_isProcessing"
                                       Class="action-btn details-action-btn">
                                Delete
                            </MudButton>
                        </Authorized>
                    </AuthorizeView>

                    <MudButton Variant="Variant.Text"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               OnClick="@(() => NavigationManager.NavigateTo("/leagues"))"
                               Class="action-btn details-action-btn back-action-btn">
                        Back
                    </MudButton>

                </div>
            </div>

            <div class="details-info-row">
                <div class="logo-wrapper">
                    @if (_league.ImageBytes != null && _league.ImageBytes.Length > 0
                                    && !string.IsNullOrEmpty(_league.ImageContentType))
                    {
                        var base64 = Convert.ToBase64String(_league.ImageBytes);
                        var src = $"data:{_league.ImageContentType};base64,{base64}";
                        <MudImage Src="@src" Alt="@_league.Name" Class="logo-image" />
                    }
                    else
                    {
                        <MudAvatar Class="logo-fallback">
                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" />
                        </MudAvatar>
                    }
                </div>

                <MudText Typo="Typo.h3" Class="details-name">@_league.Name</MudText>

                <MudChip T="string"
                         Color="@(_league.IsActive ? Color.Success : Color.Error)"
                         Size="Size.Small"
                         Class="status-chip">
                    @(_league.IsActive ? "Active" : "Inactive")
                </MudChip>
            </div>

            <MudDivider Class="my-4" />

            <MudExpansionPanels Elevation="0" Class="expansion-panels">
                <MudExpansionPanel IsInitiallyExpanded="true" Class="expansion-panel">
                    <TitleContent>
                        <div class="panel-title">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Class="panel-icon" />
                            <MudText Typo="Typo.h6">Basic Information</MudText>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <div class="info-grid">
                            <div class="info-row">
                                <div class="info-item">
                                    <MudText Class="info-label">League Name</MudText>
                                    <MudText Class="info-value">@_league.Name</MudText>
                                </div>
                                <div class="info-item">
                                    <MudText Class="info-label">Season</MudText>
                                    <MudText Class="info-value">@_league.SeasonName</MudText>
                                </div>
                                <div class="info-item">
                                    <MudText Class="info-label">Age Category</MudText>
                                    <MudText Class="info-value">@_league.AgeCategoryCode</MudText>
                                </div>
                            </div>
                            <div class="info-row">
                                <div class="info-item">
                                    <MudText Class="info-label">Gender</MudText>
                                    <MudText Class="info-value">@_league.Gender.ToDisplayString()</MudText>
                                </div>
                                <div class="info-item">
                                    <MudText Class="info-label">Competition Type</MudText>
                                    <MudText Class="info-value">@_league.CompetitionType.ToDisplayString()</MudText>
                                </div>
                                <div class="info-item">
                                    <MudText Class="info-label">Number of Rounds</MudText>
                                    <MudText Class="info-value">@_league.NumberOfRounds</MudText>
                                </div>
                            </div>
                            <div class="info-row">
                                <div class="info-item">
                                    <MudText Class="info-label">Start Date</MudText>
                                    <MudText Class="info-value">@_league.StartDate.ToString("dd.MM.yyyy.")</MudText>
                                </div>
                                <div class="info-item">
                                    <MudText Class="info-label">End Date</MudText>
                                    <MudText Class="info-value">@_league.EndDate.ToString("dd.MM.yyyy.")</MudText>
                                </div>
                                <div class="info-item">
                                    <MudText Class="info-label">Status</MudText>
                                    <MudText Class="info-value"
                                             Color="@(_league.IsActive ? Color.Success : Color.Error)">
                                        @(_league.IsActive ? "Active" : $"Deactivated on {_league.DeactivateDate?.ToString("dd.MM.yyyy.")}")
                                    </MudText>
                                </div>
                            </div>
                        </div>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudPaper>
    }
    else
    {
        <div class="error-state">
            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Large" Color="Color.Error" />
            <MudText Typo="Typo.h5" Color="Color.Error">League Not Found</MudText>
            <MudText Typo="Typo.body1">The league you're looking for doesn't exist or has been removed.</MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => NavigationManager.NavigateTo("/leagues"))">
                Back to Leagues
            </MudButton>
        </div>
    }
</MudContainer>

<ConfirmActionDialog @bind-Visible="_showDeactivateDialog"
                     Title="Confirm Deactivation"
                     TitleIcon="@Icons.Material.Filled.PauseCircle"
                     TitleIconColor="Color.Warning"
                     Message="@_deactivateMessage"
                     SecondaryMessage="This action can be reversed later."
                     SecondaryMessageColor="Color.Warning"
                     CancelText="CANCEL" CancelVariant="Variant.Outlined"
                     ConfirmText="DEACTIVATE" ConfirmIcon="@Icons.Material.Filled.Pause"
                     ConfirmColor="Color.Warning" ConfirmVariant="Variant.Filled"
                     IsProcessing="_isProcessing" OnConfirm="ConfirmDeactivate"
                     Options="_dialogOptions" />

<ConfirmActionDialog @bind-Visible="_showActivateDialog"
                     Title="Confirm Activation"
                     TitleIcon="@Icons.Material.Filled.PlayCircle"
                     TitleIconColor="Color.Success"
                     Message="@_activateMessage"
                     SecondaryMessage="This action will make the league active again."
                     SecondaryMessageColor="Color.Success"
                     CancelText="CANCEL" CancelVariant="Variant.Outlined"
                     ConfirmText="ACTIVATE" ConfirmIcon="@Icons.Material.Filled.PlayArrow"
                     ConfirmColor="Color.Success" ConfirmVariant="Variant.Filled"
                     IsProcessing="_isProcessing" OnConfirm="ConfirmActivate"
                     Options="_dialogOptions" />

<ConfirmActionDialog @bind-Visible="_showDeleteDialog"
                     Title="Confirm Deletion"
                     TitleIcon="@Icons.Material.Filled.Warning"
                     TitleIconColor="Color.Error"
                     Message="@_deleteMessage"
                     SecondaryMessage="This action cannot be undone!"
                     SecondaryMessageColor="Color.Error"
                     CancelText="CANCEL" CancelVariant="Variant.Outlined"
                     ConfirmText="DELETE" ConfirmIcon="@Icons.Material.Filled.Delete"
                     ConfirmColor="Color.Error" ConfirmVariant="Variant.Filled"
                     IsProcessing="_isProcessing" OnConfirm="ConfirmDelete"
                     Options="_dialogOptions" />
